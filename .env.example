# Copy to .env and fill in ONE provider key. Provider auto-detects from the key
# present (OpenAI preferred), or force it with MEDIA_ENGINE_PROVIDER.

# --- OpenAI (default) ---
OPENAI_API_KEY=sk-...
# gpt-5.4-mini = cheap/fast (good for testing); gpt-5.5 = best writing quality
MEDIA_ENGINE_OPENAI_MODEL=gpt-5.4-mini

# --- Anthropic (alternative) ---
# ANTHROPIC_API_KEY=sk-ant-...
# MEDIA_ENGINE_MODEL=claude-opus-4-8
# MEDIA_ENGINE_EFFORT=high

# Force a provider (optional): openai | anthropic
# MEDIA_ENGINE_PROVIDER=openai

# --- Auto-publish policy (used by: python cli.py --auto "topic") ---
# Both default off/false. Sensitive topics ALWAYS hold for a human regardless.
MEDIA_ENGINE_AUTOPUBLISH=false   # true = fire clean posts without asking
MEDIA_ENGINE_LIVE=false          # false = dry-run even when auto (safe default)
MEDIA_ENGINE_PLATFORMS=all       # or e.g. "twitter,linkedin"

# --- Publishing (NOT used in v0; wired in v3) ---
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=
# IG_ACCESS_TOKEN=
# IG_BUSINESS_ACCOUNT_ID=
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_AUTHOR_URN=
